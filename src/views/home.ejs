<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Event Board</h1>
  <p class="text-slate-500">
    Browse upcoming events and open each event's detail page.
  </p>

  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Signed in as <strong class="text-slate-700"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.email %>, role:
      <strong class="text-slate-700"><%= session.authenticatedUser.role %></strong>).
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-5xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-5 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h2 class="text-xl font-semibold text-slate-900">Available Events</h2>
      <p class="text-slate-500 mt-1">
        Select an event to view its details.
      </p>
    </div>

    <form class="w-full max-w-md">
      <label for="event-search" class="sr-only">Search events</label>
      <input
        id="event-search"
        name="q"
        type="search"
        placeholder="Search by title, description, or location"
        class="w-full rounded-xl border border-slate-300 px-4 py-2 text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none"
        hx-get="/events/search"
        hx-trigger="input changed delay:300ms, keyup[key=='Enter'], search"
        hx-target="#event-list"
        hx-swap="innerHTML"
        autocomplete="off"
      />
    </form>
  </div>

  <section id="event-list">
    <% if (!events || events.length === 0) { %>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-6 text-slate-600">
        No events available yet.
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% events.forEach((event) => { %>
          <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-slate-900"><%= event.title %></h3>
                <p class="text-sm text-slate-500 mt-1"><%= event.category %></p>
              </div>

              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                <%= event.status %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm text-slate-700">
              <p>
                <span class="font-medium">Location:</span>
                <%= event.location %>
              </p>
              <p>
                  <span class="font-medium">Start:</span>
                  <%= new Date(event.startDate).toLocaleString(undefined, {
                    dateStyle: "medium",
                    timeStyle: "short"
                  }) %>
              </p>
              <p>
                  <span class="font-medium">Start:</span>
                  <%= new Date(event.startDate).toLocaleString(undefined, {
                    dateStyle: "medium",
                    timeStyle: "short"
                  }) %>
              </p>
              <p>
                <span class="font-medium">Capacity:</span>
                <%= event.capacity %>
              </p>
            </div>

            <div class="mt-5">
              <a
                href="/events/<%= event.id %>"
                class="inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500"
              >
                View Details
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg" x-data="{ open: false }">
  <button
    @click="open = !open"
    class="w-full flex items-center justify-between text-left bg-transparent border-0 p-0 cursor-pointer"
  >
    <h2 class="text-xl font-semibold">Alpine.js Demo</h2>
    <span class="text-slate-400 text-sm" x-text="open ? 'Hide' : 'Show'">Show</span>
  </button>

  <div x-show="open" x-transition class="mt-4">
    <p class="text-slate-500 mb-3">
      Alpine.js is included via CDN and ready to use. This collapsible section is
      a quick demonstration. Use <code class="bg-slate-100 px-1 rounded text-sm">x-data</code>,
      <code class="bg-slate-100 px-1 rounded text-sm">x-show</code>,
      <code class="bg-slate-100 px-1 rounded text-sm">@click</code>, and other
      Alpine directives directly in your EJS templates.
    </p>
    <div x-data="{ count: 0 }" class="flex items-center gap-3">
      <button
        @click="count++"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm"
      >
        Clicked: <span x-text="count">0</span>
      </button>
      <span class="text-sm text-slate-500">A simple Alpine.js counter</span>
    </div>
  </div>
</section>