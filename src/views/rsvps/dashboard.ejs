<section class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-5">My RSVPs</h1>

  <% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <% if (upcoming.length === 0 && past.length === 0) { %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg text-center">
      <p class="text-slate-500">You haven't RSVP'd to any events yet.</p>
    </div>
  <% } %>

  <% if (upcoming.length > 0) { %>
    <h2 class="text-lg font-semibold text-slate-800 mb-3">Upcoming</h2>
    <div class="space-y-4 mb-8">
      <% for (const item of upcoming) { %>
        <div id="rsvp-row-<%= item.event.id %>" class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div>
              <h3 class="text-lg font-semibold text-slate-900"><%= item.event.title %></h3>
              <p class="text-sm text-slate-500 mt-1"><%= item.event.location %></p>
            </div>

            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium
              <%= item.rsvp.status === 'going'
                ? 'bg-green-100 text-green-700'
                : 'bg-yellow-100 text-yellow-700' %>">
              <%= item.rsvp.status === 'going' ? 'Going' : 'Waitlisted' %>
            </span>
          </div>

          <div class="flex items-center gap-4 mt-3 text-sm text-slate-500 flex-wrap">
            <span>
              <%= new Date(item.event.startDate).toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: 'numeric', minute: '2-digit'
              }) %>
              &ndash;
              <%= new Date(item.event.endDate).toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: 'numeric', minute: '2-digit'
              }) %>
            </span>
            <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-xs">
              <%= item.event.category %>
            </span>
          </div>

          <div class="mt-4">
            <form
              hx-post="/events/<%= item.event.id %>/rsvp"
              hx-target="#rsvp-row-<%= item.event.id %>"
              hx-swap="outerHTML"
            >
              <button
                type="submit"
                class="inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-500"
              >
                <%= item.rsvp.status === 'going' ? 'Cancel RSVP' : 'Leave Waitlist' %>
              </button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (past.length > 0) { %>
    <h2 class="text-lg font-semibold text-slate-800 mb-3">Past & Cancelled</h2>
    <div class="space-y-4">
      <% for (const item of past) { %>
        <div class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg opacity-75">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div>
              <h3 class="text-lg font-semibold text-slate-900"><%= item.event.title %></h3>
              <p class="text-sm text-slate-500 mt-1"><%= item.event.location %></p>
            </div>

            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium
              <%= item.event.status === 'cancelled'
                ? 'bg-red-100 text-red-700'
                : 'bg-slate-100 text-slate-600' %>">
              <%= item.event.status === 'cancelled' ? 'Cancelled' : 'Past' %>
            </span>
          </div>

          <div class="flex items-center gap-4 mt-3 text-sm text-slate-500 flex-wrap">
            <span>
              <%= new Date(item.event.startDate).toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: 'numeric', minute: '2-digit'
              }) %>
              &ndash;
              <%= new Date(item.event.endDate).toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: 'numeric', minute: '2-digit'
              }) %>
            </span>
            <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-xs">
              <%= item.event.category %>
            </span>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</section>
