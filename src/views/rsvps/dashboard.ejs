<section class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-5">My RSVPs</h1>

  <% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <% if (rsvps.length === 0) { %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg text-center">
      <p class="text-slate-500">You haven't RSVP'd to any events yet.</p>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% for (const item of rsvps) { %>
        <div class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div>
              <h2 class="text-lg font-semibold text-slate-900"><%= item.event.title %></h2>
              <p class="text-sm text-slate-500 mt-1"><%= item.event.location %></p>
            </div>

            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium
              <%= item.rsvp.status === 'going'
                ? 'bg-green-100 text-green-700'
                : item.rsvp.status === 'waitlisted'
                ? 'bg-yellow-100 text-yellow-700'
                : 'bg-slate-100 text-slate-600' %>">
              <%= item.rsvp.status === 'going'
                ? 'Going'
                : item.rsvp.status === 'waitlisted'
                ? 'Waitlisted'
                : 'Not Going' %>
            </span>
          </div>

          <div class="flex items-center gap-4 mt-3 text-sm text-slate-500 flex-wrap">
            <span>
              <%= new Date(item.event.startDate).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
                hour: 'numeric',
                minute: '2-digit'
              }) %>
              &ndash;
              <%= new Date(item.event.endDate).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
                hour: 'numeric',
                minute: '2-digit'
              }) %>
            </span>
            <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-xs">
              <%= item.event.category %>
            </span>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</section>