<% if (!events || events.length === 0) { %>
  <div class="rounded-xl border border-slate-200 bg-slate-50 p-6 text-slate-600">
    No matching events found.
  </div>
<% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% events.forEach((event) => { %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="text-lg font-semibold text-slate-900"><%= event.title %></h3>
            <p class="text-sm text-slate-500 mt-1"><%= event.category %></p>
          </div>

          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
            <%= event.status %>
          </span>
        </div>

        <div class="mt-4 space-y-2 text-sm text-slate-700">
          <p>
            <span class="font-medium">Location:</span>
            <%= event.location %>
          </p>
          <p>
            <span class="font-medium">Start:</span>
            <%= new Date(event.startDate).toLocaleString("en-US", {
              dateStyle: "medium",
              timeStyle: "short"
            }) %>
          </p>
          <p>
            <span class="font-medium">End:</span>
            <%= new Date(event.endDate).toLocaleString("en-US", {
              dateStyle: "medium",
              timeStyle: "short"
            }) %>
          </p>
          <p>
            <span class="font-medium">Capacity:</span>
            <%= event.capacity %>
          </p>
        </div>

        <div class="mt-5">
          <a
            href="/events/<%= event.id %>"
            class="inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500"
          >
            View Details
          </a>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>
