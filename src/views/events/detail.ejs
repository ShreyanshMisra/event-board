<div id="event-detail">
  <section class="max-w-2xl mx-auto p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <p class="text-sm font-medium text-slate-500 mb-2">Event Detail</p>
    <h1 class="text-2xl font-bold text-slate-900 mb-5"><%= event.title %></h1>

    <% if (pageError) { %>
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
        <%= pageError %>
      </div>
    <% } %>

    <div class="space-y-4 text-slate-800">
      <div>
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Description</h2>
        <p class="mt-1"><%= event.description %></p>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Location</h2>
        <p class="mt-1"><%= event.location %></p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Category</h2>
          <p class="mt-1"><%= event.category %></p>
        </div>

        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Capacity</h2>
          <p class="mt-1"><%= event.capacity %></p>
        </div>

        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Status</h2>
          <p class="mt-1"><%= event.status %></p>
        </div>

        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Organizer</h2>
          <p class="mt-1"><%= event.organizerId %></p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Start</h2>
          <p class="mt-1"><%= new Date(event.startDate).toLocaleString() %></p>
        </div>

        <div>
          <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">End</h2>
          <p class="mt-1"><%= new Date(event.endDate).toLocaleString() %></p>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-200">
      <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">
        Actions
      </h2>

      <div class="flex flex-wrap gap-3">
        <% if (canEdit) { %>
          <a
            href="/events/<%= event.id %>/edit"
            class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700"
          >
            Edit Event
          </a>
        <% } %>

        <% if (canPublish) { %>
          <button
            type="button"
            hx-post="/events/<%= event.id %>/publish"
            hx-target="#event-detail"
            hx-swap="outerHTML"
            class="inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-500"
          >
            Publish Event
          </button>
        <% } %>

        <% if (canCancel) { %>
          <button
            type="button"
            hx-post="/events/<%= event.id %>/cancel"
            hx-target="#event-detail"
            hx-swap="outerHTML"
            class="inline-flex items-center rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50"
          >
            Cancel Event
          </button>
        <% } %>

        <% if (canSave) { %>
          <%- include("../saved/partials/save-button", { eventId: event.id, isSaved }) %>
        <% } %>

      </div>

      <% if (canRsvp) { %>
        <div class="mt-4">
          <div
            id="rsvp-section"
            hx-get="/events/<%= event.id %>/rsvp-section"
            hx-trigger="load"
            hx-swap="outerHTML"
          >
            <div class="text-sm text-slate-500">Loading RSVP...</div>
          </div>
        </div>
      <% } %>
    </div>
  </section>
</div>