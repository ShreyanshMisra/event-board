generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id          String @id
  title       String
  description String
  location    String
  category    String
  capacity    Int
  startDate   String
  endDate     String
  status      String @default("draft")
  organizerId String
  createdAt   String
  updatedAt   String
}

model Rsvp {
  id        String @id
  userId    String
  eventId   String
  status    String @default("going")
  createdAt String
  updatedAt String

  @@unique([userId, eventId])
}

model SavedEvent {
  id        String @id
  userId    String
  eventId   String
  createdAt String

  @@unique([userId, eventId])
}
